# Port for the server (default: 3000)
PORT=3000

# CORS origins (comma-separated) — only needed if frontend is served from a different origin
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Database path (default: backend/wizard.db)
# DB_PATH=/data/wizard.db

# Path to built frontend files (default: ../frontend/dist)
# FRONTEND_DIR=/app/frontend/dist
